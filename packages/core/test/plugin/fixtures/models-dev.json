{
  "acme": {
    "id": "acme",
    "name": "Acme",
    "env": ["ACME_API_KEY"],
    "models": {}
  },
  "local": {
    "id": "local",
    "name": "Local",
    "env": [],
    "models": {
      "model": {
        "id": "model",
        "name": "Local Model",
        "release_date": "2026-01-01",
        "attachment": false,
        "reasoning": true,
        "temperature": true,
        "tool_call": true,
        "limit": { "context": 1000, "output": 100 },
        "experimental": {
          "modes": {
            "high": {
              "provider": { "body": { "reasoning_effort": "high" } }
            },
            "max": {
              "provider": { "headers": { "x-variant": "max" }, "body": { "reasoning_effort": "max" } }
            }
          }
        }
      }
    }
  }
}
